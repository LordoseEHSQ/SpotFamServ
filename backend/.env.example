APP_ENV=dev
APP_SECRET=change-me
DATABASE_URL="postgresql://spotfam:spotfam@127.0.0.1:5432/spotfam?serverVersion=15&charset=utf8"

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8080/api/v1/spotify/callback
FRONTEND_URL=http://localhost:5173

# Optional: Wenn gesetzt, müssen Reader-Requests den Header X-API-Key oder Authorization: Bearer <key> senden.
READER_API_KEY=

# Audio-Extractor (yt-dlp/ffmpeg). Nur für legale Quellen (eigene/CC/Public-Domain-Inhalte) –
# kein Spotify-Ripping. Verantwortung für die jeweilige URL liegt beim Nutzer.
# Optional – Defaults greifen ohne Setzen:
#AUDIO_EXTRACTOR_TIMEOUT_SECONDS=240          # Subprozess-Timeout (Schutz gegen blockierte Worker)
#AUDIO_EXTRACTOR_MAX_DURATION_SECONDS=1800    # max. Quelldauer (Sekunden)
#AUDIO_EXTRACTOR_YTDLP_BINARY=/opt/yt-dlp/yt-dlp
#AUDIO_EXTRACTOR_STORAGE_DIR=/var/www/html/var/audio   # persistenter Ablageort (Host-gemountet)
