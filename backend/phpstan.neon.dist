includes:
    - phpstan-baseline.neon

parameters:
    level: 8
    paths:
        - src
    tmpDir: var/phpstan
    # Nicht alle Baseline-Eintraege muessen matchen: Der Working Tree enthaelt
    # parallele Feature-Arbeit, daher darf eine leichte Drift die CI nicht roten.
    reportUnmatchedIgnoredErrors: false
