# SpotFam Pi-Leser – Konfigurationsvorlage
# Kopieren: cp secrets.example.env secrets.env
# secrets.env ist git-ignoriert und darf nie committet werden.

# URL des SpotFam-Backends (ohne Trailing-Slash).
# Pi-intern: http://127.0.0.1:8080 (oder die LAN-IP des Pi, wenn der Leser separat läuft)
BACKEND_BASE_URL=http://192.168.1.91:8080

# Eindeutige Reader-ID (z. B. "pi-leser-wohnzimmer"). Muss im Backend registriert sein.
# Taucht unter /api/v1/readers auf, sobald der erste Scan gesendet wurde.
READER_ID=pi-leser-wohnzimmer

# API-Key des Readers (generiert über die Readers-Seite im Frontend → "Key generieren").
# Wird als HTTP-Header "X-API-Key" gesendet.
READER_API_KEY=<hier-echtens-secret-eintragen>

# Optional: Verhalten (Defaults sind konservativ, hier nur bei Bedarf überschreiben)
# HTTP_TIMEOUT_S=8.0
# POLL_INTERVAL_S=0.2
# SCAN_COOLDOWN_S=1.5
# RETRY_BACKOFF_START_S=1.0
# RETRY_BACKOFF_MAX_S=30.0
# LOG_LEVEL=INFO
