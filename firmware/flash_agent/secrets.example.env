# SpotFam Flash-Agent – Konfigurationsvorlage
# Kopieren: cp secrets.example.env secrets.env
# secrets.env ist git-ignoriert und darf NIE committet werden.

# --- Pflichtfelder ---

# URL des SpotFam-Backends (ohne Trailing-Slash).
# Pi-intern: http://127.0.0.1:8080 (wenn Flash-Agent auf demselben Pi laeuft).
BACKEND_BASE_URL=http://192.168.1.91:8080

# API-Key des Flash-Agents (EIGENER Key, getrennt vom READER_API_KEY).
# Generiert ueber das Admin-Interface des Backends.
# Wird als HTTP-Header "X-API-Key" gesendet (D-024).
FLASH_AGENT_API_KEY=<hier-echten-key-eintragen>

# Lokales Verzeichnis mit Firmware-Artefakten (merged.bin-Dateien).
# Der Agent liest NUR Dateien aus diesem Verzeichnis (kein HTTP-Download).
# Pfad-Traversal wird hard abgeblockt (D-025).
FIRMWARE_DIR=/home/lars/SpotFamServ/firmware/flash_agent/artifacts

# --- Optionale Einstellungen (Defaults sind konservativ) ---

# Wartezeit zwischen Scan-Zyklen in Sekunden.
# POLL_INTERVAL_S=5.0

# HTTP-Timeout in Sekunden fuer Backend-Anfragen.
# HTTP_TIMEOUT_S=10.0

# Pfad oder Name des esptool-Binaers.
# ESPTOOL_BIN=esptool

# Baud-Rate fuer den Flash-Vorgang.
# FLASH_BAUD=460800

# Log-Level (DEBUG, INFO, WARNING, ERROR).
# LOG_LEVEL=INFO

# --- Flash-Zeit-NVS-Injektion (Sprint 06 / C2b) ---
# Nach erfolgreichem Firmware-Flash holt der Agent /api/v1/provisioning/reader-config
# und schreibt WLAN/Backend/OTA/Reader-Key als NVS-Partition (Namespace 'spotfam'),
# sofern die Config im Backend vollständig ist. Steuerung über die System-Card im Frontend.
#
# Injektion global an/aus (Default: an).
# INJECT_READER_CONFIG=true
#
# NVS-Offset/-Größe MÜSSEN zur Partitionstabelle der Firmware passen
# (ESP32-Arduino-Default: nvs @0x9000, size 0x5000). Hex (0x...) erlaubt.
# NVS_OFFSET=0x9000
# NVS_SIZE=0x5000
#
# NVS-Namespace, den die Reader-Firmware (Phase D) liest.
# NVS_NAMESPACE=spotfam
