# Spotify Familien Server – copy to .env and adjust

# App
APP_ENV=dev
APP_SECRET=generate-a-long-random-secret-here

# Database (when running backend locally without Docker)
DATABASE_URL="postgresql://spotfam:spotfam@127.0.0.1:5432/spotfam?serverVersion=15&charset=utf8"

# Spotify (create app at https://developer.spotify.com/dashboard; set Redirect URI to SPOTIFY_REDIRECT_URI)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Backend callback URL (must match exactly in Spotify Dashboard)
SPOTIFY_REDIRECT_URI=http://localhost:8080/api/v1/spotify/callback

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:5173

# Optional: API key for reader scan endpoint (leave empty to allow unauthenticated scans in dev)
READER_API_KEY=
